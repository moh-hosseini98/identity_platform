# .dockerignore - Essential exclusions for most projects

# Version control
.git
.gitignore
.gitattributes

# Documentation
**/*.md
docs/
LICENSE

# Docker files (prevent recursive builds)
Dockerfile*
docker-compose*
.docker/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test files
**/test/
**/tests/
**/__tests__/
**/*.test.*
**/*.spec.*
coverage/

# Build artifacts (will be generated in container)
dist/
build/
out/
target/

# Dependencies (will be installed in container)
node_modules/
vendor/
venv/
.venv/
__pycache__/
**/*.pyc

# Environment and secrets
.env
.env.*
*.pem
*.key
credentials/
secrets/

# Logs
**/*.log
**/logs/

# Temporary files
tmp/
temp/
**/*.tmp